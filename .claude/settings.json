{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pnpm typecheck)",
      "Bash(pnpm lint*)",
      "Bash(pnpm test*)",
      "Bash(pnpm build)",
      "Bash(pnpm db:generate)",
      "Bash(pnpm db:push)",
      "Bash(pnpm format)",
      "Bash(node --version)",
      "Bash(pnpm install*)",
      "Bash(pnpm dlx*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/pre-commit-checks.sh" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/post-edit-format.sh" }
        ]
      }
    ]
  }
}

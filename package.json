{
  "name": "beacon",
  "version": "0.1.0",
  "private": true,
  "description": "AI-first universal email client — Gmail, Office 365, IMAP. Mobile-ready PWA.",
  "scripts": {
    "dev": "next dev --turbopack -p 3000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "check-all": "pnpm typecheck && pnpm lint && pnpm test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@auth/drizzle-adapter": "^1.7.4",
    "@libsql/client": "^0.14.0",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@radix-ui/react-avatar": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-popover": "^1.1.4",
    "@radix-ui/react-scroll-area": "^1.2.2",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-toast": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.1.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.2.3",
    "drizzle-orm": "^0.38.3",
    "googleapis": "^144.0.0",
    "html-to-text": "^9.0.5",
    "imapflow": "^1.0.182",
    "isomorphic-dompurify": "^2.20.0",
    "lucide-react": "^0.469.0",
    "mailparser": "^3.7.2",
    "next": "15.1.4",
    "next-auth": "5.0.0-beta.25",
    "nodemailer": "^6.9.16",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@tailwindcss/postcss": "^4.0.0-beta.8",
    "@testing-library/react": "^16.1.0",
    "@types/dompurify": "^3.2.0",
    "@types/html-to-text": "^9.0.4",
    "@types/mailparser": "^3.4.5",
    "@types/node": "^22.10.5",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "19.0.2",
    "@types/react-dom": "19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "drizzle-kit": "^0.30.1",
    "eslint": "^9.17.0",
    "eslint-config-next": "15.1.4",
    "happy-dom": "^16.3.0",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.0.0-beta.8",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.0.3",
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "sharp", "unrs-resolver"]
  }
}

# ---------- Required ----------

# 32-byte hex string used to encrypt OAuth tokens / IMAP passwords at rest.
# Generate locally: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BEACON_ENCRYPTION_KEY=

# Auth.js v5 secret. Generate: openssl rand -base64 32
AUTH_SECRET=

# Public origin (used for OAuth redirect URIs and email links).
NEXTAUTH_URL=http://localhost:3000

# Anthropic API key (server-side only — never exposed to client).
ANTHROPIC_API_KEY=

# ---------- Database (LibSQL / Turso) ----------
# Local dev: file:./local.db
# Production: libsql://your-db.turso.io
DATABASE_URL=file:./local.db
DATABASE_AUTH_TOKEN=

# ---------- Gmail OAuth (Google Cloud Console) ----------
# Scopes used: https://mail.google.com/ + openid email profile
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---------- Microsoft Office 365 OAuth (Azure App Registration) ----------
# Scopes: offline_access Mail.ReadWrite Mail.Send User.Read
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
